{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "ignoreDeprecations": "6.0",
        "baseUrl": ".",
        "paths": {
            "@fixtures":["src/fixtures/index.ts"],
            "@logger":["src/utils/Loggers.ts"],
            "@waitHelpers":["src/utils/WaitHelpers.ts"],
        }

    },

    "include": [
        "src/**/*.ts",
        "tests/**/*.ts",
        "playwright.config.ts"

    ],

    "exclude": [

        "node_modules",
        "test-results",
        ".auth"
    ]


}