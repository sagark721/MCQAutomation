{
  "name": "mcqautomation2026",
  "version": "1.0.0",
  "description": "The Automation suite for MCQ",
  "main": "index.js",
  "scripts": {
    "test:setup:v3": "cross-env TEST_ENV=v3 npx playwright test --project=setup",
    "test:v3": "cross-env TEST_ENV=v3 npx playwright test",
    "test:mobile:v3": "cross-env TEST_ENV=v3 npx playwright test --project=android",
    "test:desktop:v3": "cross-env TEST_ENV=v3 npx playwright test --project=chromium --headed",
    "lint": "eslint src/**/*.ts tests/**/*.ts",
    "lint:fix": "eslint src/**/*.ts tests/**/*.ts --fix",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-playwright": "^1.8.3",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
